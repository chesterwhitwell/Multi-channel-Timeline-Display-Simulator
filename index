.settings-group .card-title{margin-bottom:12px}
.shared-settings .grid{grid-template-columns:repeat(4,minmax(0,1fr))}
.settings-storage{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:12px 14px;border-radius:12px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.065)}
.settings-storage p{margin:3px 0 0;font-size:.8rem}.danger-outline{color:var(--danger)!important;border-color:rgba(255,176,176,.25)!important;background:rgba(255,176,176,.05)!important}

/* Feedback toast */
.status-toast{position:fixed;right:20px;bottom:20px;z-index:1200;max-width:min(380px,calc(100vw - 32px));padding:11px 14px;border-radius:12px;color:#f3f5f8;background:rgba(18,21,26,.96);border:1px solid rgba(255,255,255,.13);box-shadow:0 16px 44px rgba(0,0,0,.38);font-size:.86rem;line-height:1.35;opacity:0;transform:translateY(10px) scale(.98);pointer-events:none;transition:opacity 180ms ease,transform 180ms var(--ease)}
