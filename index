    spikeChanceInput: $("spikeChanceInput"),
    timelineScaleInput: $("timelineScaleInput"),
    loopSelect: $("loopSelect"),
    contrastSelect: $("contrastSelect"),
    statusToast: $("statusToast"),
    previewCard: document.querySelector(".preview-card")
  };

  const dom = { channels: {} };
  let state = createDefaultState();
  let activeChannelCount = 2;
  let digitCache = Object.fromEntries(CHANNEL_IDS.map(ch => [ch, []]));
  let currentDisplayed = Object.fromEntries(CHANNEL_IDS.map(ch => [ch, 0]));
  let currentExact = Object.fromEntries(CHANNEL_IDS.map(ch => [ch, 0]));
  let scrubTime = 0;
  let graphData = [];
  let graphDuration = 0;
  let animationFrameId = null;
  let lastSampleTime = 0;
  let isPlaying = false;
  let isPaused = false;
  let pauseAt = 0;
  let settingsLoaded = false;
  let saveTimer = null;
