      const start=frames[graphDrag.index],end=frames[graphDrag.index+1],bezier=cleanBezier(start.bezier)||segmentBezier(start,end);
      const startX=graphMetrics.xFor(start.time),endX=graphMetrics.xFor(end.time),spanX=Math.max(1,endX-startX);
      const rawX=clamp((point.x-startX)/spanX,0,1),rangeSpan=range.max-range.min,rawValue=range.max-(point.y-p.top)/ph*rangeSpan,limitedValue=clamp(rawValue,range.min-rangeSpan*3,range.max+rangeSpan*3),step=graphValueStep(ch,range);
      if (graphDrag.handle===1) { bezier.x1=clamp(Math.round(rawX*100)/100,0,Math.max(0,bezier.x2-0.01));bezier.y1=roundToStep(limitedValue,step); }
      else { bezier.x2=clamp(Math.round(rawX*100)/100,Math.min(1,bezier.x1+0.01),1);bezier.y2=roundToStep(limitedValue,step); }
      start.bezier=bezier;start.easing="custom";scrubTime=start.time+(end.time-start.time)*(graphDrag.handle===1?bezier.x1:bezier.x2);
    }
    state.channels[ch].frames=frames;el.timeSlider.value=scrubTime;displayValues(getValuesAt(scrubTime,false));updateGraphEditStatus(graphDrag);drawGraph();
  }

  function finishGraphDrag(event) {
    if (!graphDrag) return;
    try { if (el.graphCanvas.hasPointerCapture(event.pointerId)) el.graphCanvas.releasePointerCapture(event.pointerId); } catch (_) {}
    const completed={...graphDrag};graphDrag=null;
    graphHover=completed.type==="bezier"?{type:"bezier",ch:completed.ch,index:completed.index,handle:completed.handle}:{type:"keyframe",ch:completed.ch,index:completed.index};
    renderTimeline(completed.ch);syncSlider();el.timeSlider.value=scrubTime;scheduleSave();
    setStatus(completed.type==="bezier"?`Channel ${completed.ch} transition curve updated.`:`Channel ${completed.ch} keyframe updated.`);
    const row=dom.channels[completed.ch].timelineBody.children[completed.index];if(row){row.classList.add("graph-updated");setTimeout(()=>row.classList.remove("graph-updated"),850);}
    el.graphCanvas.style.cursor="grab";drawGraph();
  }

  function scrubGraphAt(point) {
    if (!graphMetrics) return;
    const {p,pw,duration}=graphMetrics;
    scrubTime=clamp((point.x-p.left)/pw*duration,0,duration);
    el.timeSlider.value=scrubTime;stopPlayback();displayValues(getValuesAt(scrubTime,false));drawGraph();scheduleSave();
  }

  function stopPlayback(resetProgress=true) {
    if (animationFrameId!==null) { cancelAnimationFrame(animationFrameId);animationFrameId=null; }
    isPlaying=false;isPaused=false;pauseAt=0;el.playButton.textContent="Play";el.previewCard.classList.remove("is-playing","is-paused");
    if (resetProgress) el.progressBar.style.width="0%";
  }
  function pausePlayback() {
    if (!isPlaying||isPaused) return;
    isPaused=true;pauseAt=scrubTime;if(animationFrameId!==null){cancelAnimationFrame(animationFrameId);animationFrameId=null;}
    el.playButton.textContent="Resume";el.previewCard.classList.remove("is-playing");el.previewCard.classList.add("is-paused");
  }
  function togglePlayPause() { if(isPlaying&&!isPaused)pausePlayback();else if(isPaused)playTimeline(pauseAt,true);else playTimeline(0,false); }

  function playTimeline(startAt=0,preserveGraph=false) {
    if (graphEditEnabled) setGraphEditMode(false);
    if (animationFrameId!==null) cancelAnimationFrame(animationFrameId);
    syncSlider();renderTimelines();
    const duration=getDuration(),timeScale=clamp(Number(el.timelineScaleInput.value)||1,0.1,10),sampleInterval=1000/clamp(Number(el.sampleRateInput.value)||20,1,60);
    if (duration<=0) return;
    if (!preserveGraph) graphData=[];
    isPlaying=true;isPaused=false;pauseAt=0;el.playButton.textContent="Pause";el.previewCard.classList.add("is-playing");el.previewCard.classList.remove("is-paused");graphDuration=duration;
    const startTimelineTime=clamp(startAt,0,duration),startedAt=performance.now()-(startTimelineTime*1000*timeScale);lastSampleTime=performance.now()-sampleInterval;
    function animation(now) {
      const timelineTime=clamp((now-startedAt)/(1000*timeScale),0,duration),progress=duration>0?timelineTime/duration:1,shouldSample=now-lastSampleTime>=sampleInterval||progress===1;
      if (shouldSample) {
        lastSampleTime=now;scrubTime=timelineTime;el.timeSlider.value=scrubTime;
        const values=progress===1?getValuesAt(duration,false):getValuesAt(timelineTime,true);
        displayValues(values);addGraphPoint(timelineTime,values);
      }
      el.progressBar.style.width=`${progress*100}%`;
      if (progress<1) animationFrameId=requestAnimationFrame(animation);
      else {
        animationFrameId=null;isPlaying=false;isPaused=false;pauseAt=0;el.playButton.textContent="Play";el.previewCard.classList.remove("is-playing","is-paused");
        if (el.loopSelect.value==="loop") setTimeout(()=>playTimeline(0,false),250);
      }
    }
    animationFrameId=requestAnimationFrame(animation);
  }

  function setStatus(message,{announce=true,error=false}={}) {
    el.settingsStatus.textContent=message;el.settingsStatus.classList.toggle("is-error",error);el.settingsStatus.classList.remove("is-saving");
    if (!announce) return;
    clearTimeout(statusToastTimer);el.statusToast.textContent=message;el.statusToast.classList.add("is-visible");statusToastTimer=setTimeout(()=>el.statusToast.classList.remove("is-visible"),2600);
  }
  function scheduleSave() {
    if (!settingsLoaded) return;
    clearTimeout(saveTimer);el.settingsStatus.textContent="Saving…";el.settingsStatus.classList.add("is-saving");saveTimer=setTimeout(saveSettings,180);
  }

  function getSettings() {
    const channels={};
    CHANNEL_IDS.forEach(ch => { channels[ch]={frames:state.channels[ch].frames,config:{...state.channels[ch].config},axis:{...state.channels[ch].axis},collapsed:Boolean(state.channels[ch].collapsed)}; });
    return {version:5,savedAt:new Date().toISOString(),activeChannelCount,channels,playback:{sampleRate:Number(el.sampleRateInput.value)||20,settleBias:Number(el.settleBiasInput.value)||1,spikeChance:Number(el.spikeChanceInput.value)||0.08,timelineScale:Number(el.timelineScaleInput.value)||1,loop:el.loopSelect.value,contrast:el.contrastSelect.value},ui:{scrubTime,presentationMode:document.body.classList.contains("presentation-mode")}};
  }
  function saveSettings() {
    try { localStorage.setItem(STORAGE_KEY,JSON.stringify(getSettings()));if(settingsLoaded)setStatus("Saved locally",{announce:false}); }
    catch (_) { setStatus("Settings could not be saved in this browser.",{error:true}); }
  }

  function validateSettings(settings) {
    if (!settings||typeof settings!=="object") throw new Error("The file does not contain settings.");
    const defaults=createDefaultState();
    const channels={};
    CHANNEL_IDS.forEach(ch => {
      const source=settings.channels&&typeof settings.channels==="object"?settings.channels[ch]||{}:{};
      const legacyFrames=settings[`frames${ch}`];
      const sourceConfig=source.config&&typeof source.config==="object"?source.config:source;
      const base=defaults.channels[ch];
      channels[ch]={
        frames:normFrames(Array.isArray(source.frames)?source.frames:Array.isArray(legacyFrames)?legacyFrames:base.frames),
        config:{
          label:String(sourceConfig.label??base.config.label).slice(0,20),unit:String(sourceConfig.unit??base.config.unit).slice(0,8),mode:String(sourceConfig.mode??base.config.mode).slice(0,12),
          decimals:clamp(Number(sourceConfig.decimals??base.config.decimals),0,4),digits:clamp(Number(sourceConfig.digits??base.config.digits),1,8),rounding:Math.max(0,Number(sourceConfig.rounding??base.config.rounding)||0)
        },
        axis:{
          min:Number.isFinite(Number(source.axis?.min))&&source.axis?.min!==null?Number(source.axis.min):(Number.isFinite(Number(settings.graphAxes?.[ch]?.min))&&settings.graphAxes?.[ch]?.min!==null?Number(settings.graphAxes[ch].min):null),
          max:Number.isFinite(Number(source.axis?.max))&&source.axis?.max!==null?Number(source.axis.max):(Number.isFinite(Number(settings.graphAxes?.[ch]?.max))&&settings.graphAxes?.[ch]?.max!==null?Number(settings.graphAxes[ch].max):null)
        },
        collapsed:Boolean(source.collapsed??settings.ui?.collapsed?.[ch]??false)
      };
    });
    return {activeChannelCount:clamp(Number(settings.activeChannelCount??2)||2,1,4),channels,playback:settings.playback&&typeof settings.playback==="object"?settings.playback:{},ui:settings.ui&&typeof settings.ui==="object"?settings.ui:{}};
  }

  function applySettings(settings,{skipSave=false,applyPresentationMode=false,status="Settings loaded."}={}) {
    const clean=validateSettings(settings);stopPlayback();
    state.channels=clean.channels;activeChannelCount=clean.activeChannelCount;
    const playback=clean.playback;
    el.sampleRateInput.value=clamp(Number(playback.sampleRate??20),1,60);
    el.settleBiasInput.value=clamp(Number(playback.settleBias??1),0.1,5);
    el.spikeChanceInput.value=clamp(Number(playback.spikeChance??0.08),0,1);
    el.timelineScaleInput.value=clamp(Number(playback.timelineScale??1),0.1,10);
    el.loopSelect.value=playback.loop==="loop"?"loop":"once";
    el.contrastSelect.value=["normal","high","faded"].includes(playback.contrast)?playback.contrast:"normal";
    setContrast(el.contrastSelect.value);
    buildDynamicUI();syncSlider();scrubTime=clamp(Number(clean.ui.scrubTime)||0,0,getDuration());el.timeSlider.value=scrubTime;displayValues(getValuesAt(scrubTime,false));clearGraph();
    if (applyPresentationMode) setPresentationMode(Boolean(clean.ui.presentationMode));
    if (!skipSave) saveSettings();setStatus(status);
  }

  function loadSavedSettings() {
    try {
      const raw=localStorage.getItem(STORAGE_KEY)||localStorage.getItem(LEGACY_STORAGE_KEY);
      settingsLoaded=true;if(!raw)return false;
      applySettings(JSON.parse(raw),{skipSave:true,applyPresentationMode:false,status:"Saved settings loaded."});
      if (!localStorage.getItem(STORAGE_KEY)) saveSettings();
      return true;
    } catch (_) { settingsLoaded=true;setStatus("Saved settings could not be loaded. The example is being used.",{error:true});return false; }
  }

  function exportSettings() {
    saveSettings();
    const blob=new Blob([JSON.stringify(getSettings(),null,2)],{type:"application/json"}),url=URL.createObjectURL(blob),link=document.createElement("a"),stamp=new Date().toISOString().slice(0,19).replace(/[:T]/g,"-");
    link.href=url;link.download=`multi-channel-timeline-settings-${stamp}.json`;document.body.appendChild(link);link.click();link.remove();URL.revokeObjectURL(url);setStatus("Settings exported.");
  }
  function importSettings(file) {
    if (!file) return;
    const reader=new FileReader();
    reader.onload=()=>{try{applySettings(JSON.parse(String(reader.result||"")),{status:"Imported settings loaded and saved."});}catch(error){setStatus(`Import failed: ${error.message}`,{error:true});}finally{el.importSettingsFile.value="";}};
    reader.onerror=()=>setStatus("Import failed: the file could not be read.",{error:true});reader.readAsText(file);
  }
  function clearSavedSettings() { localStorage.removeItem(STORAGE_KEY);localStorage.removeItem(LEGACY_STORAGE_KEY);setStatus("Saved browser settings forgotten."); }

  function resetExample() {
    const count=activeChannelCount;state=createDefaultState();activeChannelCount=count;graphSelection=null;graphHover=null;graphData=[];scrubTime=0;buildDynamicUI();syncSlider();el.timeSlider.value=0;displayValues(getValuesAt(0,false));graphDuration=getDuration();drawGraph();saveSettings();setStatus("Example timelines restored.");
  }

  function changeChannelCount() {
    stopPlayback();activeChannelCount=clamp(Number(el.channelCountInput.value)||2,1,4);graphSelection=null;graphHover=null;graphData=[];buildDynamicUI();syncSlider();scrubTime=clamp(scrubTime,0,getDuration());el.timeSlider.value=scrubTime;displayValues(getValuesAt(scrubTime,false));graphDuration=getDuration();drawGraph();scheduleSave();setStatus(`${activeChannelCount} channel${activeChannelCount===1?"":"s"} active.`);
  }

  function setPresentationMode(enabled) {
    if (enabled&&graphEditEnabled) setGraphEditMode(false);
    document.body.classList.toggle("presentation-mode",enabled);el.presentationToggle.textContent=enabled?"Leave presentation mode":"Present";drawGraph();scheduleSave();
  }
  function isTypingTarget(target) { if(!target)return false;const tag=target.tagName?target.tagName.toLowerCase():"";return tag==="input"||tag==="select"||tag==="textarea"||target.isContentEditable; }

  el.channelCountInput.addEventListener("change",changeChannelCount);
  el.timeSlider.addEventListener("input",updateFromScrubber);
  el.playButton.addEventListener("click",togglePlayPause);
  el.stopButton.addEventListener("click",()=>stopPlayback());
  el.resetExampleButton.addEventListener("click",resetExample);
  el.clearGraphButton.addEventListener("click",clearGraph);
  el.clearSavedButton.addEventListener("click",clearSavedSettings);
  el.presentationToggle.addEventListener("click",()=>setPresentationMode(!document.body.classList.contains("presentation-mode")));
  el.presentationExit.addEventListener("click",()=>setPresentationMode(false));
  el.exportSettingsButton.addEventListener("click",exportSettings);
  el.importSettingsButton.addEventListener("click",()=>el.importSettingsFile.click());
  el.importSettingsFile.addEventListener("change",event=>importSettings(event.target.files[0]));
  el.resetGraphRangesButton.addEventListener("click",()=>{CHANNEL_IDS.forEach(ch=>{state.channels[ch].axis={min:null,max:null};if(dom.channels[ch]){dom.channels[ch].axisMin.value="";dom.channels[ch].axisMax.value="";}});drawGraph();updateAxisSummary();scheduleSave();setStatus("Graph axes set to automatic.");});
  el.graphEditToggle.addEventListener("click",()=>setGraphEditMode(!graphEditEnabled));
  el.graphEditChannelSelect.addEventListener("change",()=>{graphSelection=null;graphHover=null;el.graphEditStatus.textContent=`Channel ${getEditableChannel()} selected. Drag a keyframe, or select a segment to shape its curve.`;drawGraph();});

  [el.sampleRateInput,el.settleBiasInput,el.spikeChanceInput,el.timelineScaleInput,el.loopSelect,el.contrastSelect].forEach(control => {
    const update=()=>{setContrast(el.contrastSelect.value);state.playback={sampleRate:Number(el.sampleRateInput.value)||20,settleBias:Number(el.settleBiasInput.value)||1,spikeChance:Number(el.spikeChanceInput.value)||0.08,timelineScale:Number(el.timelineScaleInput.value)||1,loop:el.loopSelect.value,contrast:el.contrastSelect.value};displayValues(getValuesAt(scrubTime,false));drawGraph();scheduleSave();};
    control.addEventListener("input",update);control.addEventListener("change",update);
  });

  el.graphCanvas.addEventListener("pointerdown",event=>{
    const point=canvasPoint(event);
    if(graphEditEnabled){const hit=findGraphTarget(point);if(hit){event.preventDefault();if(hit.type==="segment"){selectGraphSegment(hit);return;}beginGraphDrag(event,hit);return;}graphSelection=null;graphHover=null;}
    scrubGraphAt(point);
  });
  el.graphCanvas.addEventListener("pointermove",event=>{
    if(graphDrag){event.preventDefault();updateGraphDrag(event);return;}if(!graphEditEnabled)return;
    const hit=findGraphTarget(canvasPoint(event)),signature=target=>target?`${target.type}:${target.ch}:${target.index}:${target.handle||0}`:"",changed=signature(hit)!==signature(graphHover);if(changed){graphHover=hit;drawGraph();}
    el.graphCanvas.style.cursor=hit?(hit.type==="segment"?"pointer":"grab"):"crosshair";
    if(hit){if(hit.type==="segment"){const frames=state.channels[hit.ch].frames,cfg=state.channels[hit.ch].config;el.graphEditStatus.textContent=`Select ${cfg.label} segment ${hit.index+1} (${frames[hit.index].time.toFixed(2)}–${frames[hit.index+1].time.toFixed(2)} s) to edit its curve.`;}else updateGraphEditStatus(hit);}
    else if(selectedSegmentValid()){const {ch,index}=graphSelection,start=state.channels[ch].frames[index],cfg=state.channels[ch].config;el.graphEditStatus.textContent=curveEditable(start)?`${cfg.label} segment ${index+1} selected. Drag either numbered handle; vertical overshoot is allowed.`:"Choose a continuous transition in the timeline table to edit this segment as a curve.";}
    else el.graphEditStatus.textContent=`Channel ${getEditableChannel()} selected. Drag a keyframe, or select a line segment to shape its transition.`;
  });
  el.graphCanvas.addEventListener("pointerup",finishGraphDrag);
  el.graphCanvas.addEventListener("pointercancel",finishGraphDrag);
  el.graphCanvas.addEventListener("pointerleave",()=>{if(graphDrag||!graphEditEnabled)return;graphHover=null;el.graphCanvas.style.cursor="crosshair";drawGraph();});

  window.addEventListener("resize",drawGraph);
  window.addEventListener("keydown",event=>{
    if(isTypingTarget(event.target))return;
    if(event.code==="Space"&&!event.repeat){event.preventDefault();togglePlayPause();return;}
    if(event.key==="Escape"&&document.body.classList.contains("presentation-mode"))setPresentationMode(false);
    if((event.key==="p"||event.key==="P")&&!event.repeat)setPresentationMode(!document.body.classList.contains("presentation-mode"));
  });

  function init() {
    setContrast(el.contrastSelect.value);buildDynamicUI();syncSlider();scrubTime=0;el.timeSlider.value=0;displayValues(getValuesAt(0,false));graphDuration=getDuration();drawGraph();setGraphEditMode(false);
    if(!loadSavedSettings()){settingsLoaded=true;setStatus("Saved locally",{announce:false});}
  }
  init();
})();
</script>
