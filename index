<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Multi-channel Timeline Display Simulator</title>
<style>
:root{
  --panel:#171a20;--line:rgba(255,255,255,.10);--text:#f2f4f7;--muted:#aeb6c2;
  --lcd:#b8c5a8;--lcdLight:#c7d1b8;--lcdShadow:#7c866f;
  --seg:#18201b;--segOff:rgba(24,32,27,.08);
  --blue:#9bb7ff;--green:#a8f0bd;--yellow:#ffd28a;--danger:#ffb0b0;
}
*{box-sizing:border-box}
body{margin:0;min-height:100vh;background:radial-gradient(circle at top,#2a2f37 0,#15171b 48%,#08090b 100%);color:var(--text);font-family:Arial,Helvetica,sans-serif;padding:24px;overflow-x:hidden}
.app{width:min(1360px,100%);max-width:100%;margin:0 auto;background:linear-gradient(145deg,#30343c,#181b20);border:1px solid var(--line);border-radius:28px;box-shadow:0 24px 80px rgba(0,0,0,.48);padding:28px;overflow:hidden}
.header{display:flex;justify-content:space-between;gap:20px;align-items:flex-start;margin-bottom:22px}
h1{font-size:clamp(1.3rem,3vw,2rem);margin:0 0 8px}
p{color:var(--muted);line-height:1.45}.subtitle{max-width:850px;margin:0}
.badge{white-space:nowrap;font-size:.78rem;text-transform:uppercase;letter-spacing:.14em;color:#cbd3df;padding:9px 12px;border-radius:999px;background:rgba(255,255,255,.08);border:1px solid var(--line)}
.buttons{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
button{cursor:pointer;border:0;border-radius:12px;padding:12px 14px;font-weight:700;color:#071018;background:var(--blue);min-height:44px;transition:transform 140ms ease,filter 140ms ease,background-color 140ms ease,border-color 140ms ease,box-shadow 140ms ease}
button:hover:not(:disabled){filter:brightness(1.06);transform:translateY(-1px)}button:active:not(:disabled){transform:translateY(0)}button:focus-visible{outline:0;box-shadow:0 0 0 3px rgba(155,183,255,.25)}
button.secondary{color:var(--text);background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.1)}
button.danger{color:#071018;background:var(--danger)}
button:disabled{opacity:.45;cursor:not-allowed;transform:none}
.meter{background:#0c0e12;border:8px solid #050608;border-radius:24px;padding:28px;box-shadow:inset 0 0 0 1px rgba(255,255,255,.06),inset 0 -18px 40px rgba(0,0,0,.35);overflow:hidden}
.readouts{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}
.bezel{background:#050608;border-radius:18px;padding:18px;box-shadow:inset 0 0 12px rgba(255,255,255,.08),0 8px 18px rgba(0,0,0,.45);min-width:0}
.lcd{position:relative;min-height:215px;border-radius:12px;background:linear-gradient(135deg,rgba(255,255,255,.18),transparent 35%),linear-gradient(180deg,var(--lcdLight),var(--lcd));box-shadow:inset 0 0 26px var(--lcdShadow),inset 0 -10px 24px rgba(0,0,0,.10);padding:20px 22px 26px;overflow:hidden;min-width:0}
.lcd::after{content:"";position:absolute;inset:0;pointer-events:none;background:repeating-linear-gradient(0deg,rgba(255,255,255,.055) 0,rgba(255,255,255,.055) 1px,transparent 1px,transparent 5px);mix-blend-mode:multiply;opacity:.45}
.lcd-top{position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;color:rgba(20,28,24,.72);font-weight:800;letter-spacing:.08em;margin-bottom:18px}
.lcd-status{display:flex;gap:12px;flex-wrap:wrap;font-size:.82rem}.lcd-unit{font-size:1.2rem}
.display-row {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: clamp(7px, 1.8vw, 16px);
  min-height: 132px;
  overflow: hidden;
}

.digit-container {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: clamp(7px, 1.8vw, 16px);
  min-width: 0;
}

.digit {
  --w: clamp(52px, 7vw, 78px);
  --h: calc(var(--w) * 1.8);
  --t: calc(var(--w) * 0.14);
  position: relative;
  width: var(--w);
  height: var(--h);
  filter: drop-shadow(0 2px 0 rgba(255,255,255,0.06));
  flex: 0 0 auto;
}

.segment {
  position: absolute;
  background: var(--segOff);
  transition: background 60ms ease;
}

.segment.on {
  background: var(--seg);
  box-shadow:
    0 0 2px rgba(24,32,27,0.45),
    inset 0 -2px 2px rgba(255,255,255,0.06);
}

.a, .d, .g {
  left: var(--t);
  width: calc(100% - var(--t) * 2);
  height: var(--t);
  clip-path: polygon(12% 0, 88% 0, 100% 50%, 88% 100%, 12% 100%, 0 50%);
}

.a { top: 0; }
.g { top: calc(50% - var(--t) / 2); }
.d { bottom: 0; }

.b, .c, .e, .f {
  width: var(--t);
  height: calc(50% - var(--t) * 1.3);
  clip-path: polygon(50% 0, 100% 12%, 100% 88%, 50% 100%, 0 88%, 0 12%);
}

.b { right: 0; top: calc(var(--t) * 0.65); }
.c { right: 0; bottom: calc(var(--t) * 0.65); }
.e { left: 0; bottom: calc(var(--t) * 0.65); }
.f { left: 0; top: calc(var(--t) * 0.65); }

.decimal {
  width: calc(var(--t) * 1.2);
  height: calc(var(--t) * 1.2);
  border-radius: 50%;
  background: var(--segOff);
  position: absolute;
  right: calc(var(--t) * -1.6);
  bottom: 0;
}

.decimal.on { background: var(--seg); }

.minus {
  width: clamp(24px, 4vw, 38px);
  height: clamp(8px, 1.2vw, 11px);
  margin-right: -4px;
  margin-bottom: clamp(54px, 9vw, 80px);
  background: var(--segOff);
  clip-path: polygon(12% 0, 88% 0, 100% 50%, 88% 100%, 12% 100%, 0 50%);
}

.minus.on { background: var(--seg); }
.controls{display:grid;gap:18px;margin-top:24px}
.card{background:rgba(255,255,255,.055);border:1px solid var(--line);border-radius:16px;padding:18px;min-width:0}
.card-title{display:flex;justify-content:space-between;gap:14px;align-items:baseline;margin-bottom:12px}.card-title h2{font-size:1rem;margin:0}.card-title span{color:var(--muted);font-size:.88rem}
label{display:block;color:#dfe5ee;font-weight:700;margin-bottom:9px}
input,select{width:100%;min-width:0;padding:10px 11px;border:1px solid rgba(255,255,255,.12);background:#0e1014;color:var(--text);border-radius:12px;font-size:1rem;transition:border-color 140ms ease,box-shadow 140ms ease,background-color 140ms ease}input:hover:not(:disabled),select:hover:not(:disabled){border-color:rgba(255,255,255,.22)}input:focus,select:focus{outline:0;border-color:rgba(155,183,255,.72);box-shadow:0 0 0 3px rgba(155,183,255,.12)}
input[type=range]{accent-color:var(--blue)}
.slider-line{display:grid;grid-template-columns:minmax(0,1fr) minmax(240px,auto);gap:16px;align-items:center}.value-pill{min-width:0;text-align:right;font-variant-numeric:tabular-nums;font-size:1.02rem;background:#0d0f13;border:1px solid rgba(255,255,255,.09);border-radius:12px;padding:10px 12px;color:var(--blue);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:14px}.channel-grid{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:14px}
.timeline-editor{display:grid;gap:14px}.timeline-section-heading{display:flex;align-items:flex-end;justify-content:space-between;gap:18px;padding:2px 2px 0}.timeline-section-heading h2{margin:0 0 5px;font-size:1.08rem}.timeline-section-heading p{margin:0;font-size:.9rem}.timeline-section-summary{color:#dfe5ee;font-size:.88rem;font-weight:700;white-space:nowrap;background:rgba(255,255,255,.06);border:1px solid var(--line);border-radius:999px;padding:8px 11px}
.timeline-grid{display:grid;grid-template-columns:1fr;gap:16px}.timeline-actions{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:12px}
.timeline-card{--channel-accent:var(--blue);padding:0;overflow:hidden;border-color:color-mix(in srgb,var(--channel-accent) 24%,transparent);box-shadow:inset 4px 0 0 color-mix(in srgb,var(--channel-accent) 78%,transparent)}.timeline-card.channel-b{--channel-accent:var(--green)}
.timeline-card-header{display:flex;align-items:center;justify-content:space-between;gap:18px;padding:17px 18px 15px;border-bottom:1px solid rgba(255,255,255,.075);background:linear-gradient(90deg,color-mix(in srgb,var(--channel-accent) 7%,transparent),transparent 42%)}.timeline-card.is-collapsed .timeline-card-header{border-bottom-color:transparent}.timeline-heading{display:flex;align-items:flex-start;gap:12px;min-width:0}.channel-token{display:inline-grid;place-items:center;flex:0 0 auto;min-width:34px;height:34px;border-radius:10px;color:#091018;background:var(--channel-accent);font-weight:900}.timeline-heading h2{font-size:1.03rem;margin:0 0 4px}.timeline-heading p{font-size:.86rem;margin:0;color:var(--muted)}.timeline-header-actions{display:flex;align-items:center;justify-content:flex-end;gap:10px;flex-wrap:wrap}.channel-summary{color:var(--muted);font-size:.84rem;white-space:nowrap}.add-keyframe-button{background:color-mix(in srgb,var(--channel-accent) 90%,white 10%);padding:10px 13px;min-height:40px}.collapse-toggle{display:inline-flex;align-items:center;gap:8px;min-height:40px;padding:9px 12px}.collapse-chevron{font-size:.8rem;transition:transform 180ms ease}.collapse-toggle[aria-expanded="false"] .collapse-chevron{transform:rotate(-90deg)}.timeline-card-body{min-width:0}.timeline-card-body[hidden]{display:none}
.table-wrap{overflow:visible;background:rgba(0,0,0,.14)}.timeline-table{width:100%;border-collapse:collapse;table-layout:fixed}.timeline-table th,.timeline-table td{padding:9px 8px;border-bottom:1px solid rgba(255,255,255,.06);text-align:left;vertical-align:middle}.timeline-table th{position:sticky;top:0;z-index:2;color:var(--muted);font-size:.75rem;font-weight:800;letter-spacing:.045em;text-transform:uppercase;background:#202329}.timeline-table tbody tr{transition:background-color 140ms ease}.timeline-table tbody tr:hover{background:color-mix(in srgb,var(--channel-accent) 5%,transparent)}.timeline-table tbody tr:last-child td{border-bottom:0}.timeline-table td:first-child,.timeline-table th:first-child{text-align:center}.timeline-table input,.timeline-table select{height:40px;padding:8px 10px;font-size:.92rem}.timeline-table select{padding-right:28px}.timeline-table input:disabled,.timeline-table select:disabled{opacity:.42}.keyframe-number{display:inline-grid;place-items:center;width:29px;height:29px;border-radius:999px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.08);font-weight:800;font-variant-numeric:tabular-nums}.not-applicable{display:inline-flex;align-items:center;min-height:40px;color:#78818e;font-size:.85rem}.trip-cell{text-align:center!important}.trip-toggle{position:relative;display:inline-flex;align-items:center;justify-content:center;width:42px;height:24px;cursor:pointer}.trip-toggle input{position:absolute;opacity:0;width:1px;height:1px}.trip-toggle-track{position:absolute;inset:0;border-radius:999px;background:#0d0f13;border:1px solid rgba(255,255,255,.15);transition:background 150ms ease,border-color 150ms ease}.trip-toggle-track::after{content:"";position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:#89919d;transition:transform 150ms ease,background 150ms ease}.trip-toggle input:checked+.trip-toggle-track{background:rgba(255,141,141,.22);border-color:rgba(255,141,141,.75)}.trip-toggle input:checked+.trip-toggle-track::after{transform:translateX(18px);background:#ff9a9a}.trip-toggle input:focus-visible+.trip-toggle-track{box-shadow:0 0 0 3px rgba(155,183,255,.22)}.remove-keyframe{min-height:38px;padding:8px 10px;color:#ffc1c1;background:rgba(255,176,176,.07);border:1px solid rgba(255,176,176,.18)}.remove-keyframe:hover:not(:disabled){background:rgba(255,176,176,.15);border-color:rgba(255,176,176,.35)}.timeline-footnote{display:flex;align-items:center;gap:8px;padding:10px 18px 13px;color:var(--muted);font-size:.82rem;border-top:1px solid rgba(255,255,255,.04)}.timeline-footnote::before{content:"i";display:inline-grid;place-items:center;width:18px;height:18px;border-radius:50%;background:rgba(255,255,255,.08);color:#dce3ec;font-size:.72rem;font-weight:900}
.progress{height:10px;border-radius:999px;background:rgba(255,255,255,.09);overflow:hidden;margin-top:14px}.progress-bar{height:100%;width:0;background:var(--green);border-radius:999px;transition:width 80ms linear}
.hint{margin:13px 0 0;color:var(--muted);font-size:.92rem}.graph-shell{background:#0c0e12;border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:10px}
canvas{display:block;width:100%;height:350px;border-radius:10px;background:linear-gradient(180deg,rgba(255,255,255,.03),rgba(255,255,255,.01))}
.graph-range-controls{margin-bottom:14px;padding:14px;border-radius:12px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.07)}.graph-range-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.graph-range-actions{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;margin-top:10px}.graph-range-actions .hint{margin:0}.graph-range-controls input.invalid{border-color:rgba(255,176,176,.9);box-shadow:0 0 0 2px rgba(255,176,176,.12)}.graph-title-actions{display:flex;align-items:center;justify-content:flex-end;gap:10px;flex-wrap:wrap}.graph-edit-toggle[aria-pressed="true"]{color:#071018;background:var(--yellow);border-color:transparent}.graph-edit-toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;margin:0 0 12px;padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.07)}.graph-edit-toolbar strong{color:#e9edf4}.graph-edit-status{color:var(--muted);font-size:.88rem;line-height:1.35}.graph-shell.editing{border-color:rgba(255,210,138,.44);box-shadow:0 0 0 3px rgba(255,210,138,.07)}#graphCanvas{touch-action:none}.legend,.stats{display:flex;gap:14px;flex-wrap:wrap;color:var(--muted);font-size:.9rem;margin-top:10px}.swatch{display:inline-block;width:14px;height:3px;border-radius:99px;margin-right:6px;vertical-align:middle}
.presentation-exit{display:none;position:fixed;top:16px;right:16px;z-index:1000;color:var(--text);background:rgba(6,7,10,.88);border:1px solid rgba(255,255,255,.16)}
body.presentation-mode{padding:16px;background:#08090b}body.presentation-mode .app{width:min(1440px,100%);background:transparent;border:0;box-shadow:none;padding:0}
body.presentation-mode .header,body.presentation-mode .controls>.card:not(.graph-card){display:none!important}body.presentation-mode .meter{background:transparent;border:0;box-shadow:none;padding:0}body.presentation-mode .presentation-exit{display:inline-flex}body.presentation-mode .lcd{min-height:270px}body.presentation-mode .digit{--w:clamp(52px,7vw,78px)}body.presentation-mode canvas{height:390px}
.table-wrap{max-width:100%}.card-title{min-width:0}.card-title span{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}


body.presentation-mode .scrubber-card,
body.presentation-mode .playback-card {
  display: none !important;
}

/* Presentation mode clean-up: show only readouts and graph */
body.presentation-mode .controls > .card:not(.graph-card),
body.presentation-mode .timeline-editor,
body.presentation-mode .timeline-grid,
body.presentation-mode .timeline-actions,
body.presentation-mode .table-wrap,
body.presentation-mode #rangeHint,
body.presentation-mode #settingsStatus,
body.presentation-mode .progress,
body.presentation-mode .slider-line,
body.presentation-mode .controls > .card:has(#timeSlider) {
  display: none !important;
}

body.presentation-mode .controls {
  margin-top: 18px;
}

body.presentation-mode .graph-card {
  display: block !important;
}

body.presentation-mode .graph-range-controls,
body.presentation-mode .graph-edit-toolbar,
body.presentation-mode .graph-edit-toggle {
  display: none !important;
}

