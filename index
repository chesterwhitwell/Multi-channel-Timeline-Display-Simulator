.timeline-card-body{display:grid;grid-template-rows:1fr;opacity:1;transition:grid-template-rows 260ms var(--ease),opacity 180ms ease}
.timeline-card-inner{min-height:0;overflow:hidden}
.timeline-card.is-collapsed .timeline-card-body{grid-template-rows:0fr;opacity:0;pointer-events:none}
.timeline-card.is-collapsed{box-shadow:inset 4px 0 0 color-mix(in srgb,var(--channel-accent) 55%,transparent)}
