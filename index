  }

  function displayChannel(ch,rawValue) {
    const channelDom=dom.channels[ch];
    if (!channelDom) return rawValue;
    renderDigits(ch);
    const cfg=state.channels[ch].config;
    const rounded=roundToStep(rawValue,cfg.rounding);
    const value=clamp(rounded,-getLimit(ch),getLimit(ch));
    const negative=value<0;
    const absText=Math.abs(value).toFixed(cfg.decimals);
    const parts=absText.split(".");
    const rawDigits=parts[0]+(parts[1]||"");
    const padded=rawDigits.padStart(cfg.digits," ").slice(-cfg.digits);
    const padCount=cfg.digits-rawDigits.length;
    const decimalAfter=cfg.decimals>0 ? padCount+parts[0].length-1 : -1;
    channelDom.minus.classList.toggle("on",negative);
    digitCache[ch].forEach((digitElement,index) => {
      const char=padded[index]||" ";
