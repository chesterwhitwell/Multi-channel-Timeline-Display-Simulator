  .timeline-section-heading,.timeline-card-header{align-items:flex-start;flex-direction:column}.timeline-header-actions{width:100%;justify-content:space-between}.graph-card>.card-title{align-items:flex-start;flex-direction:column}.graph-title-actions{width:100%;justify-content:space-between}.graph-edit-toolbar{align-items:flex-start;flex-direction:column}.timeline-table thead{display:none}.timeline-table,.timeline-table tbody{display:block}.timeline-table tbody{display:grid;gap:10px;padding:12px}.timeline-table tbody tr{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:11px 12px;padding:13px;border:1px solid rgba(255,255,255,.075);border-radius:13px;background:rgba(0,0,0,.16)}.timeline-table td{display:block;padding:0;border:0!important;min-width:0}.timeline-table td::before{content:attr(data-label);display:block;margin-bottom:6px;color:var(--muted);font-size:.69rem;font-weight:800;letter-spacing:.05em;text-transform:uppercase}.timeline-table td:first-child{grid-column:1/-1;text-align:left}.timeline-table td:first-child::before{display:none}.timeline-table td.actions-cell,.timeline-table td.trip-cell{align-self:end}.timeline-table td.trip-cell{text-align:left!important}.trip-toggle{margin-top:7px}.remove-keyframe{width:100%}.timeline-footnote{padding-left:14px;padding-right:14px}
}
