<body>
<button class="presentation-exit" id="presentationExit" type="button">Exit presentation mode</button>
<main class="app">
  <section class="header">
    <div>
      <h1>Multi-channel Timeline Display Simulator</h1>
      <p class="subtitle">Build, preview and compare up to four independent meter signals across a shared timeline.</p>
    </div>
    <div class="header-tools">
      <div class="channel-count-control">
        <label for="channelCountInput">Channels</label>
        <select id="channelCountInput" aria-label="Number of active channels">
          <option value="1">1 channel</option>
          <option value="2" selected>2 channels</option>
          <option value="3">3 channels</option>
          <option value="4">4 channels</option>
        </select>
      </div>
      <div class="buttons">
        <button class="secondary" id="presentationToggle" title="Show only the readouts and graph" type="button">Present</button>
        <button class="secondary" id="exportSettingsButton" title="Export all settings as JSON" type="button">Export</button>
        <button class="secondary" id="importSettingsButton" title="Import settings from a JSON file" type="button">Import</button>
        <input accept="application/json,.json" hidden id="importSettingsFile" type="file">
      </div>
    </div>
  </section>

  <section class="meter">
    <div class="readouts count-2" id="readouts"></div>

    <div class="controls">
      <section aria-labelledby="previewHeading" class="card preview-card">
        <div class="preview-header">
          <div class="section-copy">
            <h2 id="previewHeading">Preview timeline</h2>
            <p>Scrub to inspect a moment, or play the complete sequence.</p>
          </div>
          <div class="buttons preview-actions">
            <button class="play-button" id="playButton" title="Play or pause the timeline (Space)" type="button">Play</button>
            <button class="secondary" id="stopButton" title="Stop playback" type="button">Stop</button>
            <button class="secondary" id="resetExampleButton" title="Restore the example timelines and values" type="button">Restore example</button>
          </div>
        </div>
        <div class="slider-line">
          <input id="timeSlider" max="5" min="0" step="0.01" type="range" value="0">
          <div class="value-pill" id="readoutPill">0.00 s</div>
        </div>
        <div class="progress"><div class="progress-bar" id="progressBar"></div></div>
        <div class="preview-footer">
          <p class="preview-range" id="rangeHint">0.00–5.00 s</p>
          <p aria-live="polite" class="save-status" id="settingsStatus" role="status">Saved locally</p>
          <span class="shortcut-hint">Space: play/pause · P: present</span>
        </div>
      </section>

      <div class="card graph-card">
        <div class="section-header graph-header">
          <div class="section-copy">
            <h2>Timeline graph</h2>
            <p>Each channel has its own vertical scale. Click to scrub, or edit one channel at a time.</p>
          </div>
          <div class="buttons graph-actions">
            <button class="secondary compact-button" id="clearGraphButton" title="Remove recorded playback samples from the graph" type="button">Clear trace</button>
            <button aria-pressed="false" class="graph-edit-toggle secondary" id="graphEditToggle" title="Drag keyframe points and curve handles" type="button">Edit graph</button>
          </div>
        </div>

        <details class="inline-disclosure axis-disclosure">
          <summary>
            <span class="disclosure-copy"><strong>Axis ranges</strong><small>Automatic by default; each channel can use an independent fixed range.</small></span>
            <span class="disclosure-state" id="axisRangeSummary">Automatic</span>
          </summary>
          <div class="graph-range-controls">
            <div class="graph-range-grid" id="graphRangeGrid"></div>
            <div class="graph-range-actions">
              <p class="hint">Set both limits for a channel, or leave both blank to use its full timeline range.</p>
              <button class="secondary" id="resetGraphRangesButton" type="button">Auto-scale axes</button>
            </div>
          </div>
        </details>

        <div aria-live="polite" class="graph-edit-toolbar" id="graphEditToolbar">
          <strong id="graphEditModeLabel">Graph editing</strong>
          <span class="graph-edit-status" id="graphEditStatus">Drag a keyframe, or select a line segment to shape its transition.</span>
          <div class="graph-edit-channel-control">
            <label for="graphEditChannelSelect">Edit channel</label>
            <select id="graphEditChannelSelect"></select>
          </div>
        </div>

        <div class="graph-shell" id="graphShell"><canvas aria-label="Interactive multi-channel timeline graph" height="350" id="graphCanvas" width="1200"></canvas></div>
        <div class="legend" id="graphLegend"></div>
        <div class="stats" id="graphStats"></div>
      </div>

      <section aria-labelledby="timelineEditorHeading" class="timeline-editor">
        <div class="timeline-section-heading">
          <div>
            <h2 id="timelineEditorHeading">Keyframes</h2>
            <p>Use the graph for quick shaping, or open a channel for precise timing and behaviour.</p>
          </div>
          <span class="timeline-section-summary" id="timelineSummary">0 segments</span>
        </div>
        <div class="timeline-grid" id="timelineGrid"></div>
      </section>

      <details class="settings-disclosure">
        <summary><span class="disclosure-copy"><strong>Display and playback settings</strong><small>Labels, units, display precision, noise and playback behaviour.</small></span></summary>
        <div class="settings-content">
          <div class="channel-settings-grid" id="channelSettingsGrid"></div>
          <div class="settings-group shared-settings">
            <div class="card-title"><h2>Playback and signal behaviour</h2><span>All active channels</span></div>
            <div class="grid">
              <div><label for="sampleRateInput">Update rate, Hz</label><input id="sampleRateInput" max="60" min="1" type="number" value="20"></div>
              <div><label for="settleBiasInput">Noise settling</label><input id="settleBiasInput" max="5" min="0.1" step="0.1" type="number" value="1"></div>
              <div><label for="spikeChanceInput">Spike probability</label><input id="spikeChanceInput" max="1" min="0" step="0.01" type="number" value="0.08"></div>
              <div><label for="timelineScaleInput">Playback time scale</label><input id="timelineScaleInput" max="10" min="0.1" step="0.1" type="number" value="1"></div>
              <div><label for="loopSelect">Playback</label><select id="loopSelect"><option value="once">Play once</option><option value="loop">Loop</option></select></div>
              <div><label for="contrastSelect">LCD contrast</label><select id="contrastSelect"><option value="normal">Normal</option><option value="high">High</option><option value="faded">Faded</option></select></div>
            </div>
          </div>
          <div class="settings-storage">
            <div><strong>Browser storage</strong><p>All four channels are retained, even when fewer are visible.</p></div>
            <button class="secondary danger-outline" id="clearSavedButton" title="Remove saved settings from this browser without changing the current view" type="button">Forget saved settings</button>
          </div>
        </div>
      </details>
    </div>
  </section>
</main>
<div aria-atomic="true" aria-live="polite" class="status-toast" id="statusToast" role="status"></div>
<script>
(() => {
  "use strict";

  const STORAGE_KEY = "multiChannelTimeline.v5";
  const LEGACY_STORAGE_KEY = "dualIndependentTimeline.v1";
  const CHANNEL_IDS = ["A", "B", "C", "D"];
  const CHANNEL_STYLE = {
    A: { colour: "#9bb7ff", css: "var(--channel-a)", dash: [6, 4] },
