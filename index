  function activeChannels() { return CHANNEL_IDS.slice(0, activeChannelCount); }
  function clamp(value, min, max) { return Math.min(max, Math.max(min, value)); }
  function roundToStep(value, step) { return step > 0 ? Math.round(value / step) * step : value; }
  function optionHtml(options, selected) { return options.map(([value,label]) => `<option value="${value}" ${value===selected?"selected":""}>${label}</option>`).join(""); }
  function fmt(value, ch) { return Number(value).toFixed(state.channels[ch].config.decimals); }
