  }

  function updateAxisSummary() {
    const channels=activeChannels();
    let manual=0,invalid=0;
    channels.forEach(ch => { const axis=state.channels[ch].axis;if(axis.min!==null&&axis.max!==null&&axis.max>axis.min)manual++;else if((axis.min===null)!==(axis.max===null)||(axis.min!==null&&axis.max!==null&&axis.max<=axis.min))invalid++; });
