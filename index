/* Final UX refinement */
:root{--surface:#1a1d22;--surface-2:#20242a;--focus:rgba(155,183,255,.34);--ease:cubic-bezier(.2,.75,.25,1)}
body{padding:20px}
.app{padding:24px;border-radius:24px}
.header{align-items:center;margin-bottom:18px}
.header .buttons{justify-content:flex-end}
.header button{min-height:38px;padding:9px 12px;font-size:.88rem}
.subtitle{max-width:720px;font-size:.94rem}
.meter{padding:22px}
.controls{gap:16px;margin-top:18px}
.card{border-radius:15px}
.section-header,.preview-header{display:flex;align-items:flex-start;justify-content:space-between;gap:18px}
.section-copy h2,.preview-header h2{margin:0 0 4px;font-size:1.04rem}
.section-copy p,.preview-header p{margin:0;font-size:.87rem;color:var(--muted)}
.compact-button{min-height:38px;padding:9px 12px}

/* Readouts */
.bezel{position:relative;transition:transform 180ms var(--ease),box-shadow 180ms var(--ease)}
.bezel::before{content:"";position:absolute;inset:8px auto 8px 8px;width:3px;border-radius:999px;opacity:.72}
.readout-a::before{background:var(--blue)}.readout-b::before{background:var(--green)}
.bezel:hover{transform:translateY(-1px);box-shadow:inset 0 0 12px rgba(255,255,255,.08),0 10px 22px rgba(0,0,0,.5)}

/* Unified preview controls */
.preview-card{padding:16px 18px;background:linear-gradient(120deg,rgba(155,183,255,.055),rgba(255,255,255,.035) 52%)}
.preview-header{align-items:center;margin-bottom:13px}
.preview-actions{justify-content:flex-end}
.preview-actions button{min-height:40px;padding:9px 13px}
.play-button{min-width:82px;position:relative;overflow:hidden}
.play-button::after{content:"";position:absolute;inset:0;border-radius:inherit;box-shadow:inset 0 0 0 0 rgba(255,255,255,.28);transition:box-shadow 180ms ease}
.preview-card.is-playing .play-button{background:var(--yellow);box-shadow:0 0 0 3px rgba(255,210,138,.1)}
.preview-card.is-playing .play-button::after{animation:softPulse 1.4s ease-in-out infinite}
.preview-card.is-paused .play-button{background:var(--green)}
.preview-card .slider-line{grid-template-columns:minmax(0,1fr) minmax(230px,auto);gap:14px}
.preview-card .value-pill{font-size:.94rem;padding:9px 11px}
.preview-card .progress{height:5px;margin-top:12px}
.progress-bar{transition:width 80ms linear}
.preview-footer{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-top:10px;color:var(--muted);font-size:.79rem}
.preview-range{color:var(--muted)}
.save-status{display:inline-flex;align-items:center;gap:6px;color:#cbd3df}
.save-status::before{content:"";width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 0 3px rgba(168,240,189,.08)}
.save-status.is-saving::before{background:var(--yellow);animation:statusPulse .8s ease-in-out infinite}
.save-status.is-error::before{background:var(--danger)}
.shortcut-hint{opacity:.74}

/* Graph first, details second */
.graph-card{padding:17px}
.graph-header{align-items:center;margin-bottom:12px}
.graph-actions{justify-content:flex-end}
.inline-disclosure,.settings-disclosure{border:1px solid rgba(255,255,255,.075);border-radius:13px;background:rgba(255,255,255,.025);overflow:hidden}
.inline-disclosure{margin-bottom:12px}
.inline-disclosure summary,.settings-disclosure summary{list-style:none;display:flex;align-items:center;justify-content:space-between;gap:14px;padding:12px 14px;cursor:pointer;user-select:none;transition:background-color 150ms ease}
.inline-disclosure summary::-webkit-details-marker,.settings-disclosure summary::-webkit-details-marker{display:none}
.inline-disclosure summary:hover,.settings-disclosure summary:hover{background:rgba(255,255,255,.035)}
.inline-disclosure summary::after,.settings-disclosure summary::after{content:"⌄";font-size:1.15rem;color:var(--muted);transition:transform 200ms var(--ease)}
.inline-disclosure[open] summary::after,.settings-disclosure[open] summary::after{transform:rotate(180deg)}
.disclosure-copy{display:grid;gap:2px;min-width:0}.disclosure-copy strong{font-size:.92rem}.disclosure-copy small{color:var(--muted);font-size:.78rem;line-height:1.3}
.disclosure-state{margin-left:auto;color:var(--muted);font-size:.78rem;background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.07);border-radius:999px;padding:5px 8px;white-space:nowrap}
.axis-disclosure .graph-range-controls{margin:0;border:0;border-top:1px solid rgba(255,255,255,.065);border-radius:0;background:rgba(0,0,0,.09);animation:revealPanel 180ms var(--ease)}
