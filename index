    return digit;
  }

  function renderDigits(ch) {
    const channelDom=dom.channels[ch];
    if (!channelDom) return;
    const cfg=state.channels[ch].config;
    if (digitCache[ch].length === cfg.digits && channelDom.digits.children.length === cfg.digits) return;
    channelDom.digits.innerHTML="";
    digitCache[ch]=[];
    for (let i=0;i<cfg.digits;i++) { const digit=buildDigit(); channelDom.digits.appendChild(digit); digitCache[ch].push(digit); }
  }

  function getLimit(ch) {
    const cfg=state.channels[ch].config;
