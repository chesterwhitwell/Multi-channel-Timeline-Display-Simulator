    el.graphEditChannelSelect.innerHTML=channels.map(ch => `<option value="${ch}">${ch} – ${escapeHtml(state.channels[ch].config.label)}</option>`).join("");
    el.graphEditChannelSelect.value=channels.includes(previous)?previous:channels[0];
  }
  function getEditableChannel() { const value=el.graphEditChannelSelect.value;return activeChannels().includes(value)?value:activeChannels()[0]; }

