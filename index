    exportSettingsButton: $("exportSettingsButton"),
    importSettingsButton: $("importSettingsButton"),
    importSettingsFile: $("importSettingsFile"),
    channelCountInput: $("channelCountInput"),
    readouts: $("readouts"),
    timeSlider: $("timeSlider"),
