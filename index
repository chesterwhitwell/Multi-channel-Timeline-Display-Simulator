  };
  const segmentMap = {"0":["a","b","c","d","e","f"],"1":["b","c"],"2":["a","b","g","e","d"],"3":["a","b","c","d","g"],"4":["f","g","b","c"],"5":["a","f","g","c","d"],"6":["a","f","e","d","c","g"],"7":["a","b","c"],"8":["a","b","c","d","e","f","g"],"9":["a","b","c","d","f","g"]," ":[]};
  const easingOptions = [["linear","Linear"],["easeIn","Ease in"],["easeOut","Ease out"],["easeInOut","Ease in/out"],["overshoot","Overshoot and settle"],["custom","Custom curve"],["stepped","Stepped meter update"],["hold","Hold then jump"]];
  const jitterOptions = [["none","None"],["constant","Constant noise"],["settle","Settles over time"],["spike","Occasional spikes"]];
  const bezierPresetMap = {
    linear:[1/3,1/3,2/3,2/3],
