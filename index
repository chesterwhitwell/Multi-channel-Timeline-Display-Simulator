          ctx.strokeStyle="rgba(255,210,138,.58)";ctx.lineWidth=1.2;ctx.setLineDash([4,3]);ctx.beginPath();ctx.moveTo(control.anchorX,control.anchorY);ctx.lineTo(control.x,control.y);ctx.stroke();ctx.setLineDash([]);
